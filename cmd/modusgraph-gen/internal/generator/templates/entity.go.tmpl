package {{.PackageName}}
{{$name := .Entity.Name}}
{{$hasPrivate := hasPrivateFields .Entity.Fields}}
import (
	"context"
	"encoding/json"

	"github.com/matthewmcneely/modusgraph"
)

// {{$name}}Client provides typed CRUD operations for {{$name}} entities.
type {{$name}}Client struct {
	conn modusgraph.Client
}

// Get retrieves a single {{$name}} by its UID.
func (c *{{$name}}Client) Get(ctx context.Context, uid string) (*{{$name}}, error) {
{{- if $hasPrivate}}
	// Query using the reflectable struct so dgman can project all fields.
	var proxy {{lcFirst $name}}Reflectable
	err := c.conn.Get(ctx, &proxy, uid)
	if err != nil {
		return nil, err
	}
	// Unmarshal back into the entity via JSON round-trip, which invokes
	// the entity's UnmarshalJSON and populates private fields.
	data, err := json.Marshal(&proxy)
	if err != nil {
		return nil, err
	}
	var result {{$name}}
	if err := json.Unmarshal(data, &result); err != nil {
		return nil, err
	}
	return &result, nil
{{- else}}
	var result {{$name}}
	err := c.conn.Get(ctx, &result, uid)
	if err != nil {
		return nil, err
	}
	return &result, nil
{{- end}}
}

// Add inserts a new {{$name}} into the database.
func (c *{{$name}}Client) Add(ctx context.Context, v *{{$name}}) error {
	return c.conn.Insert(ctx, v)
}

// Update modifies an existing {{$name}} in the database. The UID field must be set.
func (c *{{$name}}Client) Update(ctx context.Context, v *{{$name}}) error {
	return c.conn.Update(ctx, v)
}

// Delete removes the {{$name}} with the given UID from the database.
func (c *{{$name}}Client) Delete(ctx context.Context, uid string) error {
	return c.conn.Delete(ctx, []string{uid})
}
{{if .Entity.Searchable}}
// Search finds {{$name}} entities whose {{.Entity.SearchField}} matches term using fulltext search.
func (c *{{$name}}Client) Search(ctx context.Context, term string, opts ...PageOption) ([]{{$name}}, error) {
	cfg := pageConfig{first: defaultPageSize}
	for _, opt := range opts {
		opt.applyPage(&cfg)
	}
{{- if $hasPrivate}}
	var proxies []{{lcFirst $name}}Reflectable
	q := c.conn.Query(ctx, {{lcFirst $name}}Reflectable{}).
		Filter(`alloftext({{searchPredicate .Entity}}, "` + term + `")`).
		First(cfg.first)
	if cfg.offset > 0 {
		q = q.Offset(cfg.offset)
	}
	err := q.Nodes(&proxies)
	if err != nil {
		return nil, err
	}
	return unmarshal{{$name}}Slice(proxies)
{{- else}}
	var results []{{$name}}
	q := c.conn.Query(ctx, {{$name}}{}).
		Filter(`alloftext({{searchPredicate .Entity}}, "` + term + `")`).
		First(cfg.first)
	if cfg.offset > 0 {
		q = q.Offset(cfg.offset)
	}
	err := q.Nodes(&results)
	if err != nil {
		return nil, err
	}
	return results, nil
{{- end}}
}
{{end}}
// List retrieves {{$name}} entities with optional pagination.
func (c *{{$name}}Client) List(ctx context.Context, opts ...PageOption) ([]{{$name}}, error) {
	cfg := pageConfig{first: defaultPageSize}
	for _, opt := range opts {
		opt.applyPage(&cfg)
	}
{{- if $hasPrivate}}
	var proxies []{{lcFirst $name}}Reflectable
	q := c.conn.Query(ctx, {{lcFirst $name}}Reflectable{}).
		First(cfg.first)
	if cfg.offset > 0 {
		q = q.Offset(cfg.offset)
	}
	err := q.Nodes(&proxies)
	if err != nil {
		return nil, err
	}
	return unmarshal{{$name}}Slice(proxies)
{{- else}}
	var results []{{$name}}
	q := c.conn.Query(ctx, {{$name}}{}).
		First(cfg.first)
	if cfg.offset > 0 {
		q = q.Offset(cfg.offset)
	}
	err := q.Nodes(&results)
	if err != nil {
		return nil, err
	}
	return results, nil
{{- end}}
}
{{if $hasPrivate}}
// unmarshal{{$name}}Slice converts reflectable proxies to entities via JSON round-trip.
func unmarshal{{$name}}Slice(proxies []{{lcFirst $name}}Reflectable) ([]{{$name}}, error) {
	data, err := json.Marshal(proxies)
	if err != nil {
		return nil, err
	}
	var results []{{$name}}
	if err := json.Unmarshal(data, &results); err != nil {
		return nil, err
	}
	return results, nil
}
{{end}}
